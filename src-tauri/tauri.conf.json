{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NWN2EE Save Editor",
  "version": "0.5.0",
  "identifier": "com.nwn2ee.saveeditor",
  "build": {
    "devUrl": "http://localhost:24314",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "plugins": {
    "core": {
      "injectIpcScript": true
    }
  },
  "app": {
    "windows": [
      {
        "title": "NWN2:EE Save Editor",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "devtools": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "label": "main",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [
      "../toolset-bridge/dist/toolset-bridge.exe",
      "../toolset-bridge/dist/toolset-bridge.exe.config",
      "../toolset-bridge/dist/Newtonsoft.Json.dll",
      "../toolset-bridge/dist/0Harmony.dll"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    }
  }
}